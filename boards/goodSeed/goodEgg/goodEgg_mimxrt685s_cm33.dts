/**/
/* PCA9420 PMIC */
&pmic_i2c {
	status = "okay";
	compatible = "nxp,lpc-i2c";
	clock-frequency = <I2C_BITRATE_FAST>;
	#address-cells = <1>;
	#size-cells = <0>;
	pinctrl-0 = <&pinmux_pmic_i2c>;
	pinctrl-names = "default";

	pca9420: pca9420@61 {
		compatible = "nxp,pca9420";
		reg = <0x61>;
		nxp,enable-modesel-pins;

		buck1: BUCK1 {
			regulator-boot-on;
		};

		buck2: BUCK2 {
			regulator-boot-on;
		};

		ldo1: LDO1 {
			regulator-boot-on;
		};

		ldo2: LDO2 {
			regulator-boot-on;
		};
	};
};

