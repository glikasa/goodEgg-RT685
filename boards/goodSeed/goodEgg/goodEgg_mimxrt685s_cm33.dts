//I2S transmit channel 
i2s0: &flexcomm7 {
	status = "okay";
	compatible = "nxp,lpc-i2s";
	#address-cells = <1>;
	#size-cells = <0>;
	dmas = <&dma0 15>;
	dma-names = "tx";
	pinctrl-0 = <&pinmux_flexcomm7_i2s>;
	pinctrl-names = "default";
};
