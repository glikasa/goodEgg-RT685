&sram_code {

	status = "okay";

};

/* Disable this node if not using USB and need another MPU region */
&sram1 {
	status = "okay";
};

&mbox {
	status = "okay";
};

&dmic0 {
	status = "okay";
	pinctrl-0 = <&pinmux_dmic0>;
	pinctrl-names = "default";
	use2fs;
};

