		/* magn0 = &fxos8700; */
		accel0 = &lis2dw12; 
		sdhc0 = &usdhc0;
		dmic-dev = &dmic0;
		//mcuboot-button0 = &user_button_1;
		mbox = &mbox;
		//led0 = &led0;
		adc0 = &lpadc0; 
		adpd0 = &adpd188bi;

		//bme6xx = &bme680;
		//die-temp0 = &adc_temp;
	};

	chosen {
		/* zephyr,flash-controller = &mx25um51345g; */
		zephyr,flash = &sram_code;/*&mx25um51345g; */
		zephyr,code-partition = &sram_code;
		zephyr,uart-mcumgr = &flexcomm4;
		zephyr,sram = &sram0;
		zephyr,console = &flexcomm4;
		zephyr,shell-uart = &flexcomm4;
	};

	/* leds { */
	/* 	compatible = "gpio-leds"; */
	/* 	led0: led_0 { */
	/* 		gpios = <&gpio0 14 GPIO_ACTIVE_HIGH>; */
	/* 		label = "Red LED 0"; */
	/* 	}; */
	/* }; */
	//Bitbang i2c sensor interface
	i2c_1_bitbang: i2c-gpio-1 {

		compatible = "gpio-i2c";
		label = "I2C_0_BITBANG";
		scl-gpios = <&gpio0 14 GPIO_OPEN_DRAIN >; //<&gpio7 25 GPIO_OPEN_DRAIN >; // | GPIO_PULL_UP)>; 
		sda-gpios = <&gpio0 16 GPIO_OPEN_DRAIN >; //<&gpio7 27 GPIO_OPEN_DRAIN >;
		clock-frequency = <I2C_BITRATE_STANDARD>;
		#address-cells = <1>;
		#size-cells = <0>;
		status = "okay";

		/* bme680:bme680@76 { */
		/* 	compatible = "bosch,bme680"; */
		/* 	reg = <0x76>; */
		/* 	status = "okay"; */
		/* }; */

		lis2dw12: lis2dw12@19 {
			compatible = "st,lis2dw12";
			status = "okay";
			reg = <0x19>;
			/* int1-gpios = <&gpio1 5 GPIO_ACTIVE_LOW>; */
			/* reset-gpios = <&gpio1 7 GPIO_ACTIVE_HIGH>; */
		};


	};
	i2c_0_bitbang: i2c-gpio-0 {

		compatible = "gpio-i2c";
		label = "I2C_0_BITBANG";
		scl-gpios = <&gpio7 25 GPIO_OPEN_DRAIN >; //<&gpio7 25 GPIO_OPEN_DRAIN >; // | GPIO_PULL_UP)>; 
		sda-gpios = <&gpio7 27 GPIO_OPEN_DRAIN >; //<&gpio7 27 GPIO_OPEN_DRAIN >;
		clock-frequency = <I2C_BITRATE_STANDARD>;
		#address-cells = <1>;
		#size-cells = <0>;
		status = "okay";

		/* bme680:bme680@76 { */
		/* 	compatible = "bosch,bme680"; */
		/* 	reg = <0x76>; */
		/* 	status = "okay"; */
		/* }; */

		adpd188bi: analog_adpd188@64 {
			compatible = "analog,adpd188";
			status = "okay";
			reg = <0x64>; 
			label = "ADPD188BI_SENSOR";
			int-gpios = <&gpio1 14 GPIO_ACTIVE_LOW>;
		};

		tas2563_amp: tas2563@4c {

			compatible = "ti,tas2563"; // Standard compatibility string for driver matching

			reg = <0x4c>;              // The 7-bit I2C address of the TAS2563

			// The driver will use this property to configure the I2S peripheral.
			audio-interface = <&i2s0>; 

			// a) RESET Pin (required for initial startup and soft resets)
			reset-gpios = <&gpio1 11 GPIO_ACTIVE_HIGH>; 

			// b) INTERRUPT Pin (for real-time events like short-circuit or thermal warning)
			int-gpios = <&gpio1 12 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;

			status = "okay";
		};

	};


